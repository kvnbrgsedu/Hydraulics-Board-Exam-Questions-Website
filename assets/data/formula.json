    "topic": "Open Channels",
    "formulas": [
      { "title": "Specific Energy", "formula": "\\[ \\mathbf{H} = \\frac{\\mathbf{v}^2}{2\\mathbf{g}} + \\mathbf{d} \\]" },
      { "title": "Hydraulic Radius", "formula": "R = A/P" },
      { "title": "Manning's Formula for Velocity", "formula": "\\[ v = \\frac{1}{n} R^{2/3} S^{1/2} \\]" },
      { "title": "Rectangular Section", "formula": "\\[ \\mathbf{b} = 2\\mathbf{d} \\] <br>\\[ \\mathbf{P} = \\mathbf{b} + 2\\mathbf{d} \\] <br>\\[ \\mathbf{R} = \\frac{\\mathbf{d}}{2} \\] <br>\\[ \\mathbf{A} = \\mathbf{b}\\mathbf{d} \\]" },
      { "title": "Trapezoidal Section", "formula": "x = 2y <br> R = d/2" },
      { "title": "Triangular Section", "formula": "\\[ \\mathbf{A} = d^2 \\] <br>\\[ \\mathbf{P} = 2 d \\sqrt{2} \\] <br>\\[ \\theta = 90^\\circ \\] <br>\\[ R = \\frac{d}{2 \\sqrt{2}} \\]" },
      { "title": "Circular Section", "formula": "\\[ \\mathbf{Q}_{\\max} = 93.8\\%\\ d \\] <br> \\[ \\mathbf{v}_{\\max} = 82\\%\\ d \\]" },
      { "title": "Boundary Shear Stress", "formula": "\\[ \\boldsymbol{\\tau}_o = \\gamma R S \\]" },
      { "title": "Froude Number", "formula": "\\[ \\mathbf{F_N} = \\frac{\\mathbf{v}}{\\sqrt{\\mathbf{g} \\mathbf{L}}} \\] <br> \\[ \\mathbf{F_N} = \\frac{\\mathbf{v}}{\\sqrt{\\mathbf{g} \\mathbf{d}}} \\]" },
      { "title": "Critical Depth for Rectangular Section", "formula": "\\[ \\mathbf{d}_{\\mathbf{c}} = \\frac{2}{3} \\mathbf{H} \\] <br>\\[ \\mathbf{d}_{\\mathbf{c}} = \\sqrt[3]{\\frac{\\mathbf{q}^2}{\\mathbf{g}}} \\] <br>\\[ \\mathbf{q} = \\mathbf{v} \\mathbf{d} = \\frac{\\mathbf{Q}}{\\mathbf{b}} \\]" },
      { "title": "Critical Slope for Rectangular Section", "formula": "\\[ \\mathbfit{S}_\\mathrm{c} = \\frac{g n^2}{d_{c}^{1/3}} \\]" }]
